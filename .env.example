MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password
MONGO_INITDB_DATABASE=shop

# Подключение через mongos (внутри Docker-сети; с хоста: localhost:27018)
MONGO_URL=mongodb://admin:password@mongos:27017/?authSource=admin
MONGO_DB_NAME=shop

POSTGRES_HOST=postgres-primary
POSTGRES_PORT=5432
# С хоста (psql/DBeaver): localhost:54320 primary, localhost:54321 replica
POSTGRES_DB=shop_postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
