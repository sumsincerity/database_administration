const dbName = "shop";
db = db.getSiblingDB(dbName);

function createOrUpdateRole(role) {
  if (db.getRole(role.role)) {
    db.updateRole(role.role, {
      privileges: role.privileges,
      roles: role.roles,
    });
    return;
  }

  db.createRole(role);
}

function createOrUpdateUser(user, pwd, roles) {
  if (db.getUser(user)) {
    db.updateUser(user, { pwd, roles });
    return;
  }

  db.createUser({ user, pwd, roles });
}

createOrUpdateRole({
  role: "shopAdminRole",
  privileges: [],
  roles: [{ role: "dbOwner", db: dbName }],
});

createOrUpdateRole({
  role: "shopManagerRole",
  privileges: [
    { resource: { db: dbName, collection: "products" }, actions: ["find", "insert", "update", "remove"] },
    { resource: { db: dbName, collection: "categories" }, actions: ["find", "insert", "update"] },
    { resource: { db: dbName, collection: "orders" }, actions: ["find", "update"] },
  ],
  roles: [],
});

createOrUpdateRole({
  role: "shopUserRole",
  privileges: [
    { resource: { db: dbName, collection: "products" }, actions: ["find"] },
    { resource: { db: dbName, collection: "categories" }, actions: ["find"] },
    { resource: { db: dbName, collection: "carts" }, actions: ["find", "insert", "update"] },
    { resource: { db: dbName, collection: "orders" }, actions: ["find", "insert"] },
  ],
  roles: [],
});

createOrUpdateRole({
  role: "shopGuestRole",
  privileges: [
    { resource: { db: dbName, collection: "products" }, actions: ["find"] },
    { resource: { db: dbName, collection: "categories" }, actions: ["find"] },
  ],
  roles: [],
});

createOrUpdateUser("shop_admin", "admin123", [{ role: "shopAdminRole", db: dbName }]);
createOrUpdateUser("shop_manager", "manager123", [{ role: "shopManagerRole", db: dbName }]);
createOrUpdateUser("shop_user", "user123", [{ role: "shopUserRole", db: dbName }]);
createOrUpdateUser("shop_guest", "guest123", [{ role: "shopGuestRole", db: dbName }]);